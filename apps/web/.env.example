# Firebase (Client SDK) — safe to expose in browser
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (server only — never expose)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Slack OAuth
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# DigitalOcean
DO_API_TOKEN=

# DigitalOcean region (e.g. lon1, nyc3, ams3)
DO_REGION=lon1

# Cloudflare
CF_API_TOKEN=
CF_ACCOUNT_ID=
CF_ZONE_ID=
CF_TUNNEL_HOSTNAME_ZONE=tulip.md

# App
NEXT_PUBLIC_APP_URL=https://agents.tulip.ai
NEXT_PUBLIC_RUNTIME_BASE_DOMAIN=agents.tulip.ai

# OpenClaw image to deploy on each droplet
OPENCLAW_IMAGE=ghcr.io/tulipai/openclaw:latest

# Encryption key for Slack tokens (32-byte hex)
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=
