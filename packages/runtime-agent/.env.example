# Runtime agent environment — used when running locally with `pnpm dev`.
# On a real droplet these are injected by cloud-init via /opt/tulip/agent/.env.

# URL of the Tulip control plane (your local Next.js dev server)
CONTROL_PLANE_BASE_URL=http://localhost:3001

# These three values come from a real provision + bootstrap cycle.
# For local testing, copy them from Firestore after provisioning a runtime,
# or set dummy values if you only want to exercise config loading.
INSTANCE_ID=tulip-xxxxxxxx
ORG_ID=your-org-id-here
RUNTIME_AUTH_TOKEN=your-runtime-auth-token-here

# Optional overrides
OPENCLAW_HEALTH_URL=http://127.0.0.1:3000/health
HEARTBEAT_INTERVAL_SEC=30
COMMAND_POLL_INTERVAL_SEC=15
OPENCLAW_IMAGE=ghcr.io/tulipai/openclaw:latest
